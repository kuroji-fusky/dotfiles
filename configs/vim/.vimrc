"
" Kuro's shitty Vim config
"
syntax on

set number
set relativenumber
set nocompatible
filetype off

set tabstop=2
set softtabstop=2

set shiftround
set shiftwidth=2

set expandtab
set smarttab
set smartindent
set autoindent

set nowrap
set hlsearch
set wildmenu
set wildmode=list:longest

set laststatus=2